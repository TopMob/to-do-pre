#!/usr/bin/env sh
for candidate in /usr/bin/node /usr/local/bin/node; do
  if [ -x "$candidate" ]; then
    exec "$candidate" "$@"
  fi
done
if command -v bun >/dev/null 2>&1; then
  exec "$(command -v bun)" "$@"
fi
if command -v deno >/dev/null 2>&1; then
  exec "$(command -v deno)" run "$@"
fi
printf '%s\n' 'JavaScript runtime is not available' >&2
exit 127
